# Path to the repository the agent may inspect. Relative paths resolve from this project.
REPOSITORY_PATH=../oak

# Any model from https://flueframework.com/models.json can be used.
REPO_ASSISTANT_MODEL=openrouter/qwen/qwen3-coder
OPENROUTER_API_KEY=

# Each list, read, or search call consumes one step. Allowed range: 1-20.
REPO_ASSISTANT_MAX_STEPS=8

# Set to true to log one safe line per tool call (tool name, sanitized input,
# status, result count, and budget). Disabled by default.
REPO_ASSISTANT_DEBUG=false

# Reliability: retries, timeouts, and failure injection
# Maximum retry attempts for transient failures (1-10, default 3)
REPO_ASSISTANT_MAX_ATTEMPTS=3
# Initial backoff delay in ms (default 500)
REPO_ASSISTANT_INITIAL_DELAY_MS=500
# Maximum backoff delay in ms (default 5000)
REPO_ASSISTANT_MAX_DELAY_MS=5000
# Per-operation timeout in ms (default 15000)
REPO_ASSISTANT_TIMEOUT_MS=15000

# Failure injection (for demos and testing only — do not enable in production)
# FAIL_FIRST_N_REQUESTS=2
# SIMULATE_TOOL_TIMEOUT=true
# SIMULATE_MALFORMED_RESPONSE=true
# FAIL_OPERATION=search_code
