# Path to the repository the agent may inspect. Relative paths resolve from this project.
REPOSITORY_PATH=../oak

# Any model from https://flueframework.com/models.json can be used.
REPO_ASSISTANT_MODEL=openrouter/qwen/qwen3-coder
OPENROUTER_API_KEY=

# Each list, read, or search call consumes one step. Allowed range: 1-20.
REPO_ASSISTANT_MAX_STEPS=8
