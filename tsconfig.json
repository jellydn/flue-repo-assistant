{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowArbitraryExtensions": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "agents/**/*.ts",
    "planner/**/*.ts",
    "reliability/**/*.ts",
    "investigation/**/*.ts",
    "tools/**/*.ts",
    "tests/**/*.ts",
    "sandbox.ts",
    "flue.config.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
